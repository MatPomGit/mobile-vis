<?xml version="1.0" encoding="utf-8"?>
<!--
    Capture-button background – normal (idle) state.
    Renders as a white outer ring with a white filled inner circle,
    mimicking a standard camera shutter button.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Outer ring -->
    <item>
        <shape android:shape="oval">
            <stroke
                android:width="3dp"
                android:color="@android:color/white" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>

    <!-- Inner filled circle (inset so it sits inside the ring) -->
    <item
        android:bottom="6dp"
        android:left="6dp"
        android:right="6dp"
        android:top="6dp">
        <shape android:shape="oval">
            <solid android:color="@android:color/white" />
        </shape>
    </item>

</layer-list>
