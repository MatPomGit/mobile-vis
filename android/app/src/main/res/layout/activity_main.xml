<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    tools:context="pl.edu.mobilecv.MainActivity">

    <androidx.camera.view.PreviewView
        android:id="@+id/viewFinder"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <ImageView
        android:id="@+id/imageViewPreview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@string/camera_preview_description"
        android:scaleType="fitCenter" />

    <TextView
        android:id="@+id/textViewDiagnostics"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="8dp"
        android:background="#80000000"
        android:fontFamily="monospace"
        android:padding="6dp"
        android:textColor="#FFFFFFFF"
        android:textSize="11sp"
        android:visibility="visible"
        tools:text="FPS: 30.0&#10;Rozdzielczość: 640×480&#10;Czas: 12 ms&#10;Filtr: Original&#10;Kamera: tylna" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabBackToMenu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="8dp"
        android:contentDescription="@string/back_to_menu_description"
        app:backgroundTint="#80000000"
        app:elevation="0dp"
        app:fabSize="mini"
        app:srcCompat="@android:drawable/ic_menu_revert"
        app:tint="@android:color/white" />

    <LinearLayout
        android:id="@+id/layoutRecordingIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="8dp"
        android:layout_marginEnd="56dp"
        android:background="#80000000"
        android:contentDescription="@string/recording_indicator_description"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="6dp"
        android:visibility="gone">

        <View
            android:id="@+id/viewRecordingDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/bg_recording_dot" />

        <TextView
            android:id="@+id/textViewRecordingTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:fontFamily="monospace"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            tools:text="00:00" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutContextPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#A6000000"
        android:orientation="vertical"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="8dp"
            android:paddingEnd="16dp">

            <TextView
                android:id="@+id/textViewContextModuleTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="Moduł: Morfologia" />

            <TextView
                android:id="@+id/textViewContextHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="#CCFFFFFF"
                android:textSize="11sp"
                tools:text="Wybierz filtr i dostosuj parametry do bieżącej sceny." />
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:scrollbarThumbHorizontal="@null">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupFilters"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:chipSpacingHorizontal="4dp" />
        </HorizontalScrollView>

        <TextView
            android:id="@+id/textViewCurrentFilter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingTop="6dp"
            android:paddingEnd="16dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/advanced_section_title"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btnToggleAdvanced"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/advanced_section_toggle"
                android:padding="4dp"
                android:src="@android:drawable/arrow_down_float"
                app:tint="@android:color/white" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/layoutDynamicControlsHost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <LinearLayout
            android:id="@+id/layoutAdvancedContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchActiveVision"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="4dp"
                android:text="@string/active_vision_toggle"
                android:textColor="@android:color/white"
                android:visibility="gone"
                app:thumbTint="@color/active_vision_thumb"
                app:trackTint="@color/active_vision_track" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchActiveVisionVisualization"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="2dp"
                android:text="@string/active_vision_visualization_toggle"
                android:textColor="@android:color/white"
                android:visibility="gone" />
        </LinearLayout>

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayoutModes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@android:color/transparent"
            app:tabIndicatorColor="?attr/colorSecondary"
            app:tabIndicatorHeight="3dp"
            app:tabMode="scrollable"
            app:tabSelectedTextColor="@android:color/white"
            app:tabTextAppearance="@style/TextAppearance.Material3.LabelMedium"
            app:tabTextColor="#80FFFFFF" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="8dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabSwitchCamera"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical|start"
                android:contentDescription="@string/switch_camera_description"
                app:backgroundTint="@color/button_switch_camera"
                app:elevation="0dp"
                app:fabSize="mini"
                app:srcCompat="@drawable/ic_camera_switch"
                app:tint="@android:color/white" />

            <ImageButton
                android:id="@+id/btnCapture"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_capture_button"
                android:contentDescription="@string/capture_button_description"
                android:scaleType="centerInside" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabResolution"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical|end"
                android:contentDescription="@string/resolution_fab_description"
                app:backgroundTint="#4DFFFFFF"
                app:elevation="0dp"
                app:fabSize="mini"
                app:srcCompat="@android:drawable/ic_menu_zoom"
                app:tint="@android:color/white" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabSavePointCloud"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical|end"
                android:layout_marginEnd="48dp"
                android:contentDescription="@string/save_point_cloud_description"
                android:visibility="gone"
                app:backgroundTint="#4DFFFFFF"
                app:elevation="0dp"
                app:fabSize="mini"
                app:srcCompat="@android:drawable/ic_menu_save"
                app:tint="@android:color/white" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabSaveSlamMap"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical|end"
                android:layout_marginEnd="96dp"
                android:contentDescription="@string/save_point_cloud_description"
                android:visibility="gone"
                app:backgroundTint="#4D4CAF50"
                app:elevation="0dp"
                app:fabSize="mini"
                app:srcCompat="@android:drawable/ic_menu_save"
                app:tint="@android:color/white" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabLoadSlamMap"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical|end"
                android:layout_marginEnd="144dp"
                android:contentDescription="@string/point_cloud_viewer_load"
                android:visibility="gone"
                app:backgroundTint="#4D2196F3"
                app:elevation="0dp"
                app:fabSize="mini"
                app:srcCompat="@android:drawable/ic_menu_search"
                app:tint="@android:color/white" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabEyeTrackingCalibration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical|end"
                android:layout_marginEnd="192dp"
                android:contentDescription="@string/eye_tracking_start_calibration"
                android:visibility="gone"
                app:backgroundTint="#80FF0000"
                app:elevation="0dp"
                app:fabSize="mini"
                app:srcCompat="@android:drawable/ic_menu_view"
                app:tint="@android:color/white" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabCalibrationMenu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical|end"
                android:layout_marginEnd="240dp"
                android:contentDescription="@string/calibration_menu_description"
                android:visibility="gone"
                app:backgroundTint="@color/button_calibration"
                app:elevation="0dp"
                app:fabSize="mini"
                app:srcCompat="@android:drawable/ic_menu_manage"
                app:tint="@android:color/white" />
        </FrameLayout>
    </LinearLayout>
</FrameLayout>
