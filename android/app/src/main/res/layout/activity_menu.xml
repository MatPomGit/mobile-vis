<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_menu.xml
    Main-menu screen displayed when the application launches.
    The user selects an analysis mode before the camera activity is started.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <!-- App title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textAppearance="?attr/textAppearanceHeadlineLarge"
        android:gravity="center"
        android:paddingTop="48dp"
        android:paddingBottom="8dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp" />

    <!-- Subtitle / instructions -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/menu_subtitle"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:gravity="center"
        android:paddingBottom="24dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp" />

    <!-- Scrollable list of mode cards -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/modeListContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp" />

    </ScrollView>

</LinearLayout>
