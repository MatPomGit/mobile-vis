<?xml version="1.0" encoding="utf-8"?>
<!--
    bottom_sheet_robot_connection.xml
    UI for configuring the robot IP/port and managing the ROSBridge WebSocket connection.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="?attr/colorOnSurface"
        android:alpha="0.2" />

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/robot_connection_title"
        android:textAppearance="?attr/textAppearanceHeadlineSmall"
        android:layout_marginBottom="16dp" />

    <!-- Status indicator -->
    <TextView
        android:id="@+id/textViewConnectionStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="@string/robot_status_disconnected"
        android:textAppearance="?attr/textAppearanceBodyMedium" />

    <!-- Robot host address -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilRobotHost"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/robot_host_hint"
        android:layout_marginBottom="12dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editTextRobotHost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textUri"
            android:imeOptions="actionNext"
            android:singleLine="true" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Robot rosbridge port -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilRobotPort"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/robot_port_hint"
        android:layout_marginBottom="16dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editTextRobotPort"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:imeOptions="actionDone"
            android:singleLine="true" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Connect / Disconnect button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConnectRobot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/robot_btn_connect"
        android:layout_marginBottom="8dp"
        app:icon="@android:drawable/ic_menu_share" />

</LinearLayout>
