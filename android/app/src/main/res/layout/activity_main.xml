<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_main.xml
    Layout for the main camera activity of the MobileCV application.
    Features:
      • a full-screen camera preview (CameraView);
      • a semi-transparent bottom bar containing (from top to bottom):
          - a horizontal chip bar for mode-specific controls
          - a mode-selection tab layout
          - a button row for the camera-shutter and additional actions (flip camera, etc.)
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    tools:context="pl.edu.mobilecv.MainActivity">

    <!-- The full-screen CameraX PreviewView -->
    <androidx.camera.view.PreviewView
        android:id="@+id/viewFinder"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Processed Image View -->
    <ImageView
        android:id="@+id/imageViewPreview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@string/camera_preview_description"
        android:scaleType="fitCenter" />

    <!--
        Diagnostic overlay: FPS counter and processing statistics displayed
        in the top-left corner of the camera preview.
    -->
    <TextView
        android:id="@+id/textViewDiagnostics"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="8dp"
        android:background="#80000000"
        android:fontFamily="monospace"
        android:padding="6dp"
        android:textColor="#FFFFFFFF"
        android:textSize="11sp"
        android:visibility="visible"
        tools:text="FPS: 30.0&#10;Rozdzielczość: 640×480&#10;Czas: 12 ms&#10;Filtr: Original&#10;Kamera: tylna" />

    <!-- Back to main menu button (top-right corner) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabBackToMenu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="8dp"
        android:contentDescription="@string/back_to_menu_description"
        app:backgroundTint="#80000000"
        app:elevation="0dp"
        app:fabSize="mini"
        app:srcCompat="@android:drawable/ic_menu_revert"
        app:tint="@android:color/white" />

    <!--
        Recording indicator: shown in the top-right corner only while video is
        being captured. Contains a red dot and an elapsed-time counter.
    -->
    <LinearLayout
        android:id="@+id/layoutRecordingIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="8dp"
        android:layout_marginEnd="56dp"
        android:background="#80000000"
        android:contentDescription="@string/recording_indicator_description"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="6dp"
        android:visibility="gone">

        <View
            android:id="@+id/viewRecordingDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/bg_recording_dot" />

        <TextView
            android:id="@+id/textViewRecordingTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:fontFamily="monospace"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            tools:text="00:00" />

    </LinearLayout>

    <!--
        Bottom control bar (semi-transparent dark background)
    -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#A6000000"
        android:orientation="vertical"
        android:paddingBottom="16dp">

        <!-- Kernel-size slider – shown only in MORPHOLOGY mode -->
        <LinearLayout
            android:id="@+id/layoutKernelSize"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="4dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:text="@string/morphology_kernel_size_label"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:minWidth="80dp" />

            <SeekBar
                android:id="@+id/seekBarKernelSize"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_weight="1"
                android:max="19"
                android:progress="3"
                android:progressTint="@android:color/white"
                android:thumbTint="@android:color/white" />

            <TextView
                android:id="@+id/textViewKernelSize"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="8dp"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                tools:text="9×9" />

        </LinearLayout>

        <!-- VO Max Features slider -->
        <LinearLayout
            android:id="@+id/layoutVoMaxFeatures"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="4dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:text="@string/vo_max_features_label"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:minWidth="100dp" />

                <SeekBar
                    android:id="@+id/seekBarVoMaxFeatures"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_weight="1"
                    android:max="5000"
                    android:progress="300"
                    android:progressTint="@android:color/white"
                    android:thumbTint="@android:color/white" />

                <TextView
                    android:id="@+id/textViewVoMaxFeatures"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="8dp"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    tools:text="300" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/vo_max_features_hint"
                android:textColor="#AAFFFFFF"
                android:textSize="10sp"
                android:paddingTop="2dp" />

        </LinearLayout>

        <!-- VO Min Parallax slider -->
        <LinearLayout
            android:id="@+id/layoutVoMinParallax"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="4dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:text="@string/vo_min_parallax_label"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:minWidth="100dp" />

                <SeekBar
                    android:id="@+id/seekBarVoMinParallax"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_weight="1"
                    android:max="500"
                    android:progress="10"
                    android:progressTint="@android:color/white"
                    android:thumbTint="@android:color/white" />

                <TextView
                    android:id="@+id/textViewVoMinParallax"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="8dp"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    tools:text="1.0" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/vo_min_parallax_hint"
                android:textColor="#AAFFFFFF"
                android:textSize="10sp"
                android:paddingTop="2dp" />

        </LinearLayout>

        <!-- VO Mesh toggle -->
        <LinearLayout
            android:id="@+id/layoutVoMesh"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="4dp"
            android:visibility="gone">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_weight="1"
                android:text="@string/vo_mesh_toggle"
                android:textColor="@android:color/white"
                android:textSize="12sp" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchVoMesh"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutPoseTemporalControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="4dp"
            android:visibility="gone">

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchPoseSmoothing"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pose_smoothing_toggle"
                android:textColor="@android:color/white" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchPoseOneEuro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pose_smoothing_one_euro_toggle"
                android:textColor="@android:color/white" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchPoseRawVsSmoothed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pose_raw_vs_smoothed_toggle"
                android:textColor="@android:color/white" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:minWidth="120dp"
                    android:text="@string/pose_ema_alpha_label"
                    android:textColor="@android:color/white"
                    android:textSize="12sp" />

                <SeekBar
                    android:id="@+id/seekBarPoseEmaAlpha"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_weight="1"
                    android:max="95"
                    android:progress="35"
                    android:progressTint="@android:color/white"
                    android:thumbTint="@android:color/white" />

                <TextView
                    android:id="@+id/textViewPoseEmaAlpha"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="8dp"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    tools:text="0.35" />
            </LinearLayout>
        </LinearLayout>

        <!-- Mode-specific context chips (e.g., settings for the current filter) -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:scrollbarThumbHorizontal="@null">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupFilters"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:chipSpacingHorizontal="4dp" />

        </HorizontalScrollView>

        <TextView
            android:id="@+id/textViewCurrentFilter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:visibility="gone" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchActiveVision"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="4dp"
            android:text="@string/active_vision_toggle"
            android:textColor="@android:color/white"
            android:visibility="gone"
            app:thumbTint="@color/active_vision_thumb"
            app:trackTint="@color/active_vision_track" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchActiveVisionVisualization"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="2dp"
            android:text="@string/active_vision_visualization_toggle"
            android:textColor="@android:color/white"
            android:visibility="gone" />

        <!-- ============================================================ -->
        <!-- Analysis-mode tab bar (relocated from the top of the screen  -->
        <!-- to the bottom for easier one-handed thumb access)            -->
        <!-- ============================================================ -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayoutModes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@android:color/transparent"
            app:tabTextColor="#80FFFFFF"
            app:tabSelectedTextColor="@android:color/white"
            app:tabIndicatorColor="?attr/colorSecondary"
            app:tabIndicatorHeight="3dp"
            app:tabMode="scrollable"
            app:tabTextAppearance="@style/TextAppearance.Material3.LabelMedium" />

        <!--
            Button row:
              • camera-switch FAB   – pinned to the start
              • calibration FAB     – pinned to the end (visible in Calibration mode only)
              • shutter button      – centred
        -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="8dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <!-- Switch Camera -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabSwitchCamera"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical|start"
                android:contentDescription="@string/switch_camera_description"
                app:backgroundTint="@color/button_switch_camera"
                app:elevation="0dp"
                app:fabSize="mini"
                app:srcCompat="@drawable/ic_camera_switch"
                app:tint="@android:color/white" />

            <!-- Resolution Picker (shown to the right of the switch-camera FAB) -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabResolution"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical|start"
                android:layout_marginStart="48dp"
                android:contentDescription="@string/resolution_fab_description"
                app:backgroundTint="#4DFFFFFF"
                app:elevation="0dp"
                app:fabSize="mini"
                app:srcCompat="@android:drawable/ic_menu_zoom"
                app:tint="@android:color/white" />

            <!-- Main Shutter / Action Button -->
            <ImageButton
                android:id="@+id/btnCapture"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_capture_button"
                android:contentDescription="@string/capture_button_description"
                android:scaleType="centerInside" />

            <!-- Robot Connection FAB -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabRobotConnection"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical|end"
                android:contentDescription="@string/robot_connection_description"
                app:backgroundTint="@color/button_robot_default"
                app:elevation="0dp"
                app:fabSize="mini"
                app:srcCompat="@android:drawable/ic_menu_share"
                app:tint="@android:color/white" />

            <!-- Save Point Cloud FAB (visible only during POINT_CLOUD filter) -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabSavePointCloud"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical|end"
                android:layout_marginEnd="48dp"
                android:contentDescription="@string/save_point_cloud_description"
                android:visibility="gone"
                app:backgroundTint="#4DFFFFFF"
                app:elevation="0dp"
                app:fabSize="mini"
                app:srcCompat="@android:drawable/ic_menu_save"
                app:tint="@android:color/white" />

            <!-- Calibration (optional FAB, visible when in calibration mode) -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabCalibrationMenu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical|end"
                android:contentDescription="@string/calibration_menu_description"
                android:visibility="gone"
                app:backgroundTint="@color/button_calibration"
                app:elevation="0dp"
                app:fabSize="mini"
                app:srcCompat="@android:drawable/ic_menu_manage"
                app:tint="@android:color/white" />

        </FrameLayout>

    </LinearLayout>

</FrameLayout>
