<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_main.xml
    Full-screen processed camera preview with:
      • a semi-transparent bottom bar containing (from top to bottom):
          – a filter chip group for selecting the active sub-filter,
          – a scrollable TabLayout for switching analysis modes, and
          – a button row with camera-switch FAB, capture button, and action FAB.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    tools:context=".MainActivity">

    <!-- ================================================================ -->
    <!-- Camera preview (fills the area above the bottom bar)             -->
    <!-- ================================================================ -->
    <ImageView
        android:id="@+id/imageViewPreview"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:contentDescription="@string/camera_preview_description"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ================================================================ -->
    <!-- Bottom control bar (semi-transparent dark background)            -->
    <!-- Contains (top to bottom):                                        -->
    <!--   1. Active filter label                                         -->
    <!--   2. Horizontally scrollable filter chip group                   -->
    <!--   3. Analysis-mode tab bar (moved from the top for ergonomics)   -->
    <!--   4. Camera action buttons (switch | capture | settings FAB)     -->
    <!-- ================================================================ -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#CC000000"
        android:paddingTop="8dp"
        android:paddingBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Active filter label -->
        <TextView
            android:id="@+id/textViewCurrentFilter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:layout_marginBottom="4dp"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:background="#33FFFFFF"
            android:text="@string/filter_label_original"
            tools:text="Original" />

        <!-- Horizontally scrollable row of filter chips -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupFilters"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:chipSpacingHorizontal="4dp" />

        </HorizontalScrollView>

        <!-- ============================================================ -->
        <!-- Analysis-mode tab bar (relocated from the top of the screen  -->
        <!-- to the bottom for easier one-handed thumb access)            -->
        <!-- ============================================================ -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayoutModes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="transparent"
            app:tabTextColor="#80FFFFFF"
            app:tabSelectedTextColor="@android:color/white"
            app:tabIndicatorColor="?attr/colorSecondary"
            app:tabIndicatorHeight="3dp"
            app:tabMode="scrollable"
            app:tabTextAppearance="@style/TextAppearance.Material3.LabelSmall" />

        <!--
            Button row:
              • camera-switch FAB   – pinned to the start
              • calibration FAB     – pinned to the end (visible in Calibration mode only)
              • shutter button      – centred
        -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginTop="8dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <!-- Camera-switch FAB (left) -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabSwitchCamera"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start|center_vertical"
                android:contentDescription="@string/switch_camera_description"
                app:srcCompat="@drawable/ic_camera_switch"
                app:fabSize="mini" />

            <!-- Capture / shutter button (centre) -->
            <ImageButton
                android:id="@+id/btnCapture"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_capture_button"
                android:contentDescription="@string/capture_button_description"
                android:src="@null"
                tools:background="@drawable/bg_capture_button_normal" />

            <!-- Calibration menu FAB (right, calibration mode only) -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabCalibrationMenu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end|center_vertical"
                android:contentDescription="@string/calibration_menu_description"
                android:visibility="gone"
                app:srcCompat="@android:drawable/ic_menu_manage"
                app:fabSize="mini"
                tools:visibility="visible" />

            <!-- Robot connection FAB (right, all modes except Calibration) -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabRobotConnection"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end|center_vertical"
                android:contentDescription="@string/robot_connection_description"
                android:visibility="visible"
                app:srcCompat="@android:drawable/ic_menu_share"
                app:fabSize="mini" />

        </FrameLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
