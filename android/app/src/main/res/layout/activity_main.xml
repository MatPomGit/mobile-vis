<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_main.xml
    Layout for the main camera activity of the MobileCV application.
    Features:
      • a full-screen camera preview (CameraView);
      • a semi-transparent bottom bar containing (from top to bottom):
          - a horizontal chip bar for mode-specific controls
          - a mode-selection tab layout
          - a button row for the camera-shutter and additional actions (flip camera, etc.)
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    tools:context="pl.edu.mobilecv.MainActivity">

    <!-- The full-screen CameraX PreviewView -->
    <androidx.camera.view.PreviewView
        android:id="@+id/viewFinder"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Processed Image View -->
    <ImageView
        android:id="@+id/imageViewPreview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@string/camera_preview_description"
        android:scaleType="fitCenter" />

    <!--
        Diagnostic overlay: FPS counter and processing statistics displayed
        in the top-left corner of the camera preview.
    -->
    <TextView
        android:id="@+id/textViewDiagnostics"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="8dp"
        android:background="#80000000"
        android:fontFamily="monospace"
        android:padding="6dp"
        android:textColor="#FFFFFFFF"
        android:textSize="11sp"
        android:visibility="visible"
        tools:text="FPS: 30.0&#10;Rozdzielczość: 640×480&#10;Czas: 12 ms&#10;Filtr: Original&#10;Kamera: tylna" />

    <!--
        Bottom control bar (semi-transparent dark background)
    -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#A6000000"
        android:orientation="vertical"
        android:paddingBottom="16dp">

        <!-- Mode-specific context chips (e.g., settings for the current filter) -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:scrollbarThumbHorizontal="@null">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupFilters"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:chipSpacingHorizontal="4dp" />

        </HorizontalScrollView>

        <TextView
            android:id="@+id/textViewCurrentFilter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:visibility="gone" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchActiveVision"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="4dp"
            android:text="@string/active_vision_toggle"
            android:textColor="@android:color/white"
            app:thumbTint="@color/active_vision_thumb"
            app:trackTint="@color/active_vision_track" />

        <!-- ============================================================ -->
        <!-- Analysis-mode tab bar (relocated from the top of the screen  -->
        <!-- to the bottom for easier one-handed thumb access)            -->
        <!-- ============================================================ -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayoutModes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@android:color/transparent"
            app:tabTextColor="#80FFFFFF"
            app:tabSelectedTextColor="@android:color/white"
            app:tabIndicatorColor="?attr/colorSecondary"
            app:tabIndicatorHeight="3dp"
            app:tabMode="scrollable"
            app:tabTextAppearance="@style/TextAppearance.Material3.LabelMedium" />

        <!--
            Button row:
              • camera-switch FAB   – pinned to the start
              • calibration FAB     – pinned to the end (visible in Calibration mode only)
              • shutter button      – centred
        -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginTop="8dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <!-- Switch Camera -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabSwitchCamera"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical|start"
                android:contentDescription="@string/switch_camera_description"
                app:backgroundTint="@color/button_switch_camera"
                app:elevation="0dp"
                app:fabSize="mini"
                app:srcCompat="@drawable/ic_camera_switch"
                app:tint="@android:color/white" />

            <!-- Resolution Picker (shown to the right of the switch-camera FAB) -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabResolution"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical|start"
                android:layout_marginStart="52dp"
                android:contentDescription="@string/resolution_fab_description"
                app:backgroundTint="#4DFFFFFF"
                app:elevation="0dp"
                app:fabSize="mini"
                app:srcCompat="@android:drawable/ic_menu_zoom"
                app:tint="@android:color/white" />

            <!-- Main Shutter / Action Button -->
            <ImageButton
                android:id="@+id/btnCapture"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_capture_button"
                android:contentDescription="@string/capture_button_description"
                android:scaleType="centerInside" />

            <!-- Robot Connection FAB -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabRobotConnection"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical|end"
                android:contentDescription="@string/robot_connection_description"
                app:backgroundTint="@color/button_robot_default"
                app:elevation="0dp"
                app:fabSize="mini"
                app:srcCompat="@android:drawable/ic_menu_share"
                app:tint="@android:color/white" />

            <!-- Calibration (optional FAB, visible when in calibration mode) -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabCalibrationMenu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical|end"
                android:contentDescription="@string/calibration_menu_description"
                android:visibility="gone"
                app:backgroundTint="@color/button_calibration"
                app:elevation="0dp"
                app:fabSize="mini"
                app:srcCompat="@android:drawable/ic_menu_manage"
                app:tint="@android:color/white" />

        </FrameLayout>

    </LinearLayout>

</FrameLayout>
