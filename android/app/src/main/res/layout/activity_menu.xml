<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_menu.xml
    Main-menu screen displayed when the application launches.
    The user selects an analysis mode before the camera activity is started.
    Five tabs:
      "Przetwarzanie" – basic image-processing modes (FILTERS / EDGES / MORPHOLOGY / EFFECTS)
      "Detekcja"      – detection modes (MARKERS / YOLO / POSE)
      "Analiza 3D"    – spatial-analysis modes (ODOMETRY / GEOMETRY / CALIBRATION)
      "Modele"        – model download status and manual-download buttons
      "O aplikacji"   – app description and per-filter descriptions
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <!-- App title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textAppearance="?attr/textAppearanceHeadlineLarge"
        android:gravity="center"
        android:paddingTop="48dp"
        android:paddingBottom="8dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp" />

    <!-- Version number displayed under the app name -->
    <TextView
        android:id="@+id/textAppVersion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingBottom="4dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textAppearance="?attr/textAppearanceLabelMedium"
        android:textColor="?attr/colorOnSurfaceVariant" />

    <!--
        Tab bar: Przetwarzanie | Detekcja | Analiza 3D | Modele | O aplikacji
        scrollable mode because 5 tabs may not fit in a fixed layout on all screen sizes
    -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayoutMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:tabMode="scrollable"
        app:tabGravity="start"
        app:tabIndicatorHeight="3dp" />

    <!-- Content frame – one child visible at a time based on the selected tab -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- "Przetwarzanie" tab: FILTERS, EDGES, MORPHOLOGY, EFFECTS -->
        <ScrollView
            android:id="@+id/scrollViewModes"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:id="@+id/modeListContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="16dp" />

        </ScrollView>

        <!-- "Detekcja" tab: MARKERS, YOLO, POSE -->
        <ScrollView
            android:id="@+id/scrollViewDetection"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/detectionContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="16dp" />

        </ScrollView>

        <!-- "Analiza 3D" tab: ODOMETRY, GEOMETRY, CALIBRATION + PointCloudViewer -->
        <ScrollView
            android:id="@+id/scrollViewAnalysis"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/analysisContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="16dp" />

        </ScrollView>

        <!-- "Modele" tab: MediaPipe and YOLO model status + download buttons -->
        <ScrollView
            android:id="@+id/scrollViewModels"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/modelsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="8dp"
                android:paddingBottom="16dp" />

        </ScrollView>

        <!-- "O aplikacji" tab: app description + per-filter descriptions -->
        <ScrollView
            android:id="@+id/scrollViewAbout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/aboutContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="16dp" />

        </ScrollView>

    </FrameLayout>

</LinearLayout>
