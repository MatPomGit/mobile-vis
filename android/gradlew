#!/bin/sh
# Gradle start-up script for UN*X
# (Standard script generated by Gradle, reproduced here for completeness.)
# Requires: Java 17+ on the PATH. Gradle itself is downloaded automatically
# from the URL specified in gradle/wrapper/gradle-wrapper.properties once the
# gradle-wrapper.jar bootstrap file is present.  Generate it with:
#
#   gradle wrapper --gradle-version 8.6
#
# Or open the project in Android Studio, which generates the wrapper for you.

set -e

# Resolve the script location
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
APP_HOME="$SCRIPT_DIR"

# Default JVM options
DEFAULT_JVM_OPTS='"-Xmx64m" "-Xms64m"'

# OS-specific settings
case "$(uname -s)" in
  CYGWIN*|MSYS*|MINGW*)
    APP_HOME=$(cygpath --unix "$APP_HOME")
    ;;
esac

# Locate java
if [ -n "$JAVA_HOME" ]; then
  JAVA_CMD="$JAVA_HOME/bin/java"
else
  JAVA_CMD="java"
fi

CLASSPATH="$APP_HOME/gradle/wrapper/gradle-wrapper.jar"
exec "$JAVA_CMD" $DEFAULT_JVM_OPTS \
  -classpath "$CLASSPATH" \
  org.gradle.wrapper.GradleWrapperMain "$@"
