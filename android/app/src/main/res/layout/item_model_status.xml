<?xml version="1.0" encoding="utf-8"?>
<!--
    item_model_status.xml
    A single row in the Models tab of the main menu.
    Shows the model name, download status and a download/downloaded action button.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="16dp"
    android:paddingEnd="8dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <!-- Coloured status dot: green = downloaded, grey = missing -->
    <View
        android:id="@+id/viewModelStatusDot"
        android:layout_width="14dp"
        android:layout_height="14dp"
        android:background="@drawable/bg_recording_dot"
        android:backgroundTint="@color/model_status_missing" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp">

        <TextView
            android:id="@+id/textModelName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceTitleSmall" />

        <TextView
            android:id="@+id/textModelSize"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorOnSurfaceVariant" />

    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnModelAction"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/model_btn_download" />

</LinearLayout>
