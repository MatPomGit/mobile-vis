<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_point_cloud_viewer.xml
    Layout for viewing a loaded point cloud file.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/black">

    <!-- Toolbar row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#CC000000"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <Button
            android:id="@+id/btnBackFromViewer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/back_to_menu_description"
            android:textSize="12sp"
            style="?attr/materialButtonOutlinedStyle" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_gravity="center_vertical"
            android:text="@string/mode_point_cloud_viewer"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:gravity="center"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />

        <Button
            android:id="@+id/btnLoadPointCloud"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/point_cloud_viewer_load"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Status text -->
    <TextView
        android:id="@+id/textViewCloudStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#80000000"
        android:textColor="#AAFFFFFF"
        android:textSize="12sp"
        android:padding="8dp"
        android:gravity="center"
        android:fontFamily="monospace"
        tools:text="Wczytano 1234 punktów"
        xmlns:tools="http://schemas.android.com/tools" />

    <!-- Point cloud canvas -->
    <pl.edu.mobilecv.PointCloudView
        android:id="@+id/pointCloudView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
