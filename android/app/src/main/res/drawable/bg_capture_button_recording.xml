<?xml version="1.0" encoding="utf-8"?>
<!--
    Capture-button background – recording state.
    Renders as a red outer ring with a red filled inner circle
    to indicate that video recording is in progress.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Outer ring (red) -->
    <item>
        <shape android:shape="oval">
            <stroke
                android:width="3dp"
                android:color="#FFFF0000" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>

    <!-- Inner filled circle (red) -->
    <item
        android:bottom="6dp"
        android:left="6dp"
        android:right="6dp"
        android:top="6dp">
        <shape android:shape="oval">
            <solid android:color="#FFFF0000" />
        </shape>
    </item>

</layer-list>
