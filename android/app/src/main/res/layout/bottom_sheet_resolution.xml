<?xml version="1.0" encoding="utf-8"?>
<!--
    bottom_sheet_resolution.xml
    UI for selecting the camera resolution used during live analysis.
    Follows the same visual structure as bottom_sheet_robot_connection.xml.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="?attr/colorOnSurface"
        android:alpha="0.2" />

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/resolution_title"
        android:textAppearance="?attr/textAppearanceHeadlineSmall"
        android:layout_marginBottom="8dp" />

    <!-- Description -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/resolution_description"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:layout_marginBottom="16dp" />

    <!-- Resolution radio buttons (populated programmatically) -->
    <RadioGroup
        android:id="@+id/radioGroupResolution"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp" />

    <!-- Apply button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnApplyResolution"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/resolution_btn_apply"
        android:layout_marginBottom="8dp" />

</LinearLayout>
