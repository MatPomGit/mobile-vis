<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_menu.xml
    Main-menu screen displayed when the application launches.
    The user selects an analysis mode before the camera activity is started.
    Two tabs: "Tryby" (mode cards) and "O aplikacji" (app & effect descriptions).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <!-- App title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textAppearance="?attr/textAppearanceHeadlineLarge"
        android:gravity="center"
        android:paddingTop="48dp"
        android:paddingBottom="8dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp" />

    <!-- Version number displayed under the app name -->
    <TextView
        android:id="@+id/textAppVersion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingBottom="4dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textAppearance="?attr/textAppearanceLabelMedium"
        android:textColor="?attr/colorOnSurfaceVariant" />

    <!-- Tab bar: Tryby | O aplikacji -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayoutMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:tabGravity="fill"
        app:tabMode="fixed"
        app:tabIndicatorHeight="3dp" />

    <!-- Content frame – one child visible at a time based on the selected tab -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- "Tryby" tab: scrollable list of mode cards -->
        <ScrollView
            android:id="@+id/scrollViewModes"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:id="@+id/modeListContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="16dp" />

        </ScrollView>

        <!-- "O aplikacji" tab: app description + per-filter descriptions -->
        <ScrollView
            android:id="@+id/scrollViewAbout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/aboutContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="16dp" />

        </ScrollView>

    </FrameLayout>

</LinearLayout>
